{
  "name": "akira/laravel-sisp",
  "description": "this is a laravel package to handle SISP payment",
  "keywords": [
    "Akira",
    "laravel",
    "laravel-sisp"
  ],
  "homepage": "https://github.com/akira-io/laravel-sisp",
  "license": "MIT",
  "authors": [
    {
      "name": "Kidiatoliny",
      "email": "kidiatoliny@akira-io.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "akira/laravel-crypto": "^0.1.1",
    "illuminate/contracts": "^11.0||^12.0",
    "pinkary-project/type-guard": "^0.1.0",
    "spatie/laravel-package-tools": "^1.92.4"
  },
  "require-dev": {
    "larastan/larastan": "^v2.10.0",
    "laravel/pint": "^1.22.0",
    "nunomaduro/collision": "^8.8",
    "orchestra/testbench": "^9.13.0||^10.2.1",
    "peckphp/peck": "^0.1.3",
    "pestphp/pest": "^3.8.2",
    "pestphp/pest-plugin-arch": "^3.1.1",
    "pestphp/pest-plugin-laravel": "^3.1",
    "pestphp/pest-plugin-type-coverage": "^3.5",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^1.12.24",
    "phpstan/phpstan-deprecation-rules": "^1.2.1",
    "phpstan/phpstan-phpunit": "^1.4.2",
    "rector/rector": "^1.2.10",
    "spatie/laravel-ray": "^1.40.2"
  },
  "autoload": {
    "psr-4": {
      "Akira\\Sisp\\": "src/",
      "Akira\\Sisp\\Database\\Factories\\": "database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Akira\\Sisp\\Tests\\": "tests/",
      "Workbench\\App\\": "workbench/app/"
    }
  },
  "scripts": {
    "post-autoload-dump": "@composer run prepare",
    "clear": "@php vendor/bin/testbench package:purge-laravel-sisp --ansi",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "build": [
      "@composer run prepare",
      "@php vendor/bin/testbench workbench:build --ansi"
    ],
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@composer run build",
      "@php vendor/bin/testbench serve"
    ],
    "lint": "pint",
    "refactor": "rector",
    "test:lint": "pint --test",
    "test:refactor": "rector --dry-run",
    "test:arch": "pest --filter=arch",
    "test:type-coverage": "pest --type-coverage --min=100 ",
    "test:coverage": "pest --parallel --coverage --compact --exactly=5.8",
    "test:typos": "peck",
    "test": [
      "@test:lint",
      "@test:refactor",
      "@test:typos",
      "@test:arch",
      "@test:type-coverage",
      "@test:coverage"
    ]
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Akira\\Sisp\\SispServiceProvider"
      ],
      "aliases": {
        "Sisp": "Akira\\Sisp\\Facades\\Sisp"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
