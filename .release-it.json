{
  "git": {
    "requireBranch": "1.x",
    "commitMessage": "chore: release v${version}",
    "requireCommits": false,
    "changelog": true,
    "tag": true,
    "push": true,
    "pushArgs": "--follow-tags"
  },
  "npm": false,
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "web": true,
    "draft": false,
    "preRelease": false,
    "skipChecks": true
  },
  "hooks": {
    "before:init": [
      "composer test"
    ],
    "after:release": "echo Successfully released v${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "preset": "angular",
      "types": {
        "feat": {
          "section": "Features"
        },
        "fix": {
          "section": "Bug Fixes"
        },
        "perf": {
          "section": "Performance"
        },
        "docs": {
          "section": "Documentation",
          "hidden": true
        },
        "style": {
          "section": "Styling",
          "hidden": true
        },
        "refactor": {
          "section": "Code Refactoring"
        },
        "test": {
          "section": "Tests",
          "hidden": true
        },
        "chore": {
          "section": "Build & CI/CD",
          "hidden": true
        }
      }
    }
  }
}